# postiz-mobile configuration. Copy to `.env` and fill in.
# NONE of these are secrets — do not put credentials here. postiz-mobile holds
# no API keys or passwords; it authenticates each user against your Postiz.

# Where your Postiz backend is reachable FROM THIS CONTAINER.
# If Postiz runs on the same Docker host (loopback), use host.docker.internal:
POSTIZ_UPSTREAM=http://host.docker.internal:4007

# Must match your Postiz STORAGE_PROVIDER: 'local' (disk) or 'cloudflare' (S3/R2).
STORAGE_PROVIDER=local

# ONLY for STORAGE_PROVIDER=cloudflare: the public origin of your object store,
# so the browser may upload/preview media there and the CSP allows it.
# Example: https://media.example.com  (leave empty for local storage)
MEDIA_ORIGIN=

# Loopback port on the Docker host that your reverse proxy / tunnel forwards to.
HOST_PORT=4008

# Container listen port (rarely changed).
LISTEN_PORT=8080
